# Public, local-development-only defaults.
#
# These values are intentionally usable after copying this file to `.env`, but
# they are committed examples and therefore are not secrets. All Compose ports
# bind to 127.0.0.1. Never reuse these credentials in a shared or production
# environment.

AKOS_POSTGRES_DB=akos_fabric
AKOS_POSTGRES_USER=akos_fabric
AKOS_POSTGRES_PASSWORD=akos-local-postgres-7P3n6Nf4wR9k
AKOS_POSTGRES_PORT=5432

AKOS_RABBITMQ_USER=akos_fabric
AKOS_RABBITMQ_PASSWORD=akos-local-rabbitmq-4J8m2Qv7sT5x
AKOS_RABBITMQ_AMQP_PORT=5672
AKOS_RABBITMQ_MANAGEMENT_PORT=15672

